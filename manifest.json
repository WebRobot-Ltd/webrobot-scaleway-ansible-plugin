{
  "pluginId": "scaleway-vm-adapter",
  "version": "0.1.0",
  "displayName": "Scaleway VM Adapter",
  "description": "Cloud-provider VM adapter for Scaleway (Instance API). Implements the WebRobot vm-adapter contract for Spark elastic VM provisioning.",
  "author": "WebRobot",
  "license": "Apache-2.0",
  "homepage": "https://github.com/WebRobot-Ltd/webrobot-scaleway-ansible-plugin",
  "components": [
    {
      "type": "vm-adapter",
      "providerKey": "scaleway",
      "ansibleRole": "scaleway_adapter",
      "supportedActions": ["create", "delete", "list", "health"],
      "regions": [
        "fr-par-1",
        "fr-par-2",
        "fr-par-3",
        "nl-ams-1",
        "nl-ams-2",
        "nl-ams-3",
        "pl-waw-1",
        "pl-waw-2",
        "pl-waw-3"
      ],
      "instanceTypes": [
        { "key": "DEV1-S",   "vcpu": 2, "memMb": 2048,  "monthlyEur": 4.0 },
        { "key": "DEV1-M",   "vcpu": 3, "memMb": 4096,  "monthlyEur": 8.0 },
        { "key": "DEV1-L",   "vcpu": 4, "memMb": 8192,  "monthlyEur": 14.0 },
        { "key": "DEV1-XL",  "vcpu": 4, "memMb": 12288, "monthlyEur": 18.0 },
        { "key": "GP1-XS",   "vcpu": 4, "memMb": 16384, "monthlyEur": 32.0 },
        { "key": "GP1-S",    "vcpu": 8, "memMb": 32768, "monthlyEur": 64.0 },
        { "key": "GP1-M",    "vcpu": 16, "memMb": 65536, "monthlyEur": 128.0 },
        { "key": "PLAY2-PICO",  "vcpu": 1, "memMb": 2048, "monthlyEur": 5.0 },
        { "key": "PLAY2-NANO",  "vcpu": 2, "memMb": 4096, "monthlyEur": 9.0 },
        { "key": "PLAY2-MICRO", "vcpu": 4, "memMb": 8192, "monthlyEur": 17.0 }
      ],
      "apiVersion": "v1",
      "complianceFlags": ["gdpr", "data_residency_eu"],
      "egressDomains": ["api.scaleway.com"],
      "healthProbeUrl": "https://api.scaleway.com/instance/v1/zones/fr-par-1/servers"
    }
  ]
}
